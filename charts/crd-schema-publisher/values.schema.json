{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["mode", "image"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["controller", "cronjob"],
      "description": "Deployment mode"
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of replicas (controller mode only)"
    },
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "description": "Container image repository"
        },
        "tag": {
          "type": "string",
          "description": "Image tag"
        },
        "digest": {
          "type": "string",
          "description": "Image digest"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "description": "Image pull policy"
        }
      }
    },
    "existingSecret": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of an existing Secret"
        }
      }
    },
    "externalSecret": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Create an ExternalSecret resource"
        }
      }
    }
  },
  "oneOf": [
    {
      "properties": {
        "existingSecret": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["name"]
        },
        "externalSecret": {
          "type": "object",
          "properties": {
            "enabled": {
              "enum": [false]
            }
          }
        }
      }
    },
    {
      "properties": {
        "existingSecret": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "maxLength": 0
            }
          }
        },
        "externalSecret": {
          "type": "object",
          "properties": {
            "enabled": {
              "enum": [true]
            }
          },
          "required": ["enabled"]
        }
      }
    }
  ]
}
