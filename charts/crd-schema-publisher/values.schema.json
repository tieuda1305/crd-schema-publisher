{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "mode": {
      "type": "string",
      "enum": [
        "controller",
        "cronjob"
      ],
      "description": "Deployment mode"
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of replicas (controller mode only)"
    },
    "image": {
      "type": "object",
      "required": [
        "repository"
      ],
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "description": "Container image repository"
        },
        "tag": {
          "type": "string",
          "description": "Image tag"
        },
        "digest": {
          "type": "string",
          "description": "Image digest"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "description": "Image pull policy"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets for private registries",
      "items": {
        "type": "object"
      }
    },
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name"
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full release name"
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cfPagesProject": {
          "type": "string",
          "description": "Cloudflare Pages project name"
        },
        "outputDir": {
          "type": "string",
          "description": "Schema output directory inside the container"
        },
        "debounceSeconds": {
          "type": [
            "string",
            "integer"
          ],
          "description": "Seconds to wait after the last CRD event before publishing (controller only)"
        },
        "healthPort": {
          "type": "integer",
          "description": "Health/metrics server port (controller only)"
        },
        "leaseName": {
          "type": "string",
          "description": "Leader election lease name (controller only)"
        },
        "skipRender": {
          "type": [
            "string",
            "boolean"
          ],
          "description": "Set to true to skip HTML schema page rendering"
        },
        "basePath": {
          "type": "string",
          "description": "URL path prefix for subpath deployments (e.g., /iac)"
        }
      }
    },
    "existingSecret": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of an existing Secret"
        }
      }
    },
    "externalSecret": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Create an ExternalSecret resource"
        },
        "secretStoreRef": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "SecretStore or ClusterSecretStore name"
            },
            "kind": {
              "type": "string",
              "enum": [
                "SecretStore",
                "ClusterSecretStore"
              ],
              "description": "SecretStore or ClusterSecretStore"
            }
          }
        },
        "refreshInterval": {
          "type": "string",
          "description": "Refresh interval for the external secret"
        },
        "data": {
          "type": "array",
          "description": "Remote key mappings",
          "items": {
            "type": "object",
            "properties": {
              "secretKey": {
                "type": "string",
                "description": "Key name in the resulting Secret"
              },
              "remoteRef": {
                "type": "object",
                "properties": {
                  "key": {
                    "type": "string",
                    "description": "Remote secret key"
                  },
                  "property": {
                    "type": "string",
                    "description": "Remote secret property"
                  }
                }
              }
            }
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create a ServiceAccount"
        },
        "automount": {
          "type": "boolean",
          "description": "Automount the service account token"
        },
        "annotations": {
          "type": "object",
          "description": "Additional annotations for the ServiceAccount"
        },
        "name": {
          "type": "string",
          "description": "Override the ServiceAccount name"
        }
      }
    },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create ClusterRole/ClusterRoleBinding for CRD read access"
        }
      }
    },
    "cronjob": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schedule": {
          "type": "string",
          "description": "Cron schedule expression"
        },
        "concurrencyPolicy": {
          "type": "string",
          "enum": [
            "Allow",
            "Forbid",
            "Replace"
          ],
          "description": "Concurrency policy for the CronJob"
        },
        "successfulJobsHistoryLimit": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of successful job completions to retain"
        },
        "failedJobsHistoryLimit": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of failed job completions to retain"
        },
        "activeDeadlineSeconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum runtime for each job in seconds"
        },
        "restartPolicy": {
          "type": "string",
          "enum": [
            "OnFailure",
            "Never"
          ],
          "description": "Restart policy for job pods"
        }
      }
    },
    "strategy": {
      "type": "object",
      "description": "Deployment update strategy"
    },
    "resources": {
      "type": "object",
      "description": "Container resource requests and limits"
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Pod security context (applied to the pod spec)"
    },
    "securityContext": {
      "type": "object",
      "description": "Container security context"
    },
    "livenessProbe": {
      "type": "object",
      "description": "Liveness probe configuration (controller mode only)"
    },
    "readinessProbe": {
      "type": "object",
      "description": "Readiness probe configuration (controller mode only)"
    },
    "annotations": {
      "type": "object",
      "description": "Annotations added to the Deployment or CronJob metadata"
    },
    "podAnnotations": {
      "type": "object",
      "description": "Annotations added to the pod template metadata"
    },
    "podLabels": {
      "type": "object",
      "description": "Additional pod labels"
    },
    "nodeSelector": {
      "type": "object",
      "description": "Node selector constraints"
    },
    "tolerations": {
      "type": "array",
      "description": "Tolerations for pod scheduling",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object",
      "description": "Affinity rules (controller mode only)"
    },
    "topologySpreadConstraints": {
      "type": "array",
      "description": "Topology spread constraints (controller mode only)",
      "items": {
        "type": "object"
      }
    },
    "podAntiAffinityPreset": {
      "type": "string",
      "enum": [
        "",
        "soft",
        "hard"
      ],
      "description": "Pod anti-affinity preset (controller mode only)"
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Create a PodDisruptionBudget"
        },
        "minAvailable": {
          "type": [
            "integer",
            "string"
          ],
          "description": "Minimum number of available pods"
        },
        "maxUnavailable": {
          "type": [
            "integer",
            "string"
          ],
          "description": "Maximum number of unavailable pods"
        }
      }
    },
    "priorityClassName": {
      "type": "string",
      "description": "Priority class name for pods"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "podMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create a PodMonitor for Prometheus Operator"
            },
            "interval": {
              "type": "string",
              "description": "Scrape interval"
            },
            "labels": {
              "type": "object",
              "description": "Additional labels for the PodMonitor"
            }
          }
        },
        "prometheusRule": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create PrometheusRule alerts"
            },
            "labels": {
              "type": "object",
              "description": "Additional labels for the PrometheusRule"
            },
            "rules": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "watchdogStaleSeconds": {
                  "type": "integer",
                  "description": "Watchdog stale threshold in seconds"
                },
                "watchdogStaleFor": {
                  "type": "string",
                  "description": "Duration before watchdog stale alert fires"
                },
                "noPublishSeconds": {
                  "type": "integer",
                  "description": "No successful publish threshold in seconds"
                },
                "noPublishFor": {
                  "type": "string",
                  "description": "Duration before no-publish alert fires"
                },
                "errorSpikeThreshold": {
                  "type": "integer",
                  "description": "Error spike threshold (errors per hour)"
                },
                "errorSpikeFor": {
                  "type": "string",
                  "description": "Duration before error spike alert fires"
                }
              }
            }
          }
        }
      }
    },
    "grafana": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dashboard": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Install the Grafana dashboard as a ConfigMap"
            },
            "label": {
              "type": "string",
              "description": "Label key for Grafana sidecar discovery"
            },
            "labelValue": {
              "type": "string",
              "description": "Label value for Grafana sidecar discovery"
            },
            "folder": {
              "type": "string",
              "description": "Folder annotation for the Grafana sidecar"
            }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Create a NetworkPolicy"
        },
        "extraEgress": {
          "type": "array",
          "description": "Egress rules",
          "items": {
            "type": "object"
          }
        },
        "extraIngress": {
          "type": "array",
          "description": "Extra ingress rules",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "ciliumNetworkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Create a CiliumNetworkPolicy"
        },
        "extraEgress": {
          "type": "array",
          "description": "Egress rules",
          "items": {
            "type": "object"
          }
        },
        "extraIngress": {
          "type": "array",
          "description": "Extra ingress rules",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Use a PVC for the output directory"
        },
        "existingClaim": {
          "type": "string",
          "description": "Name of an existing PVC"
        },
        "storageClass": {
          "type": "string",
          "description": "Storage class name"
        },
        "accessModes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "PVC access modes"
        },
        "size": {
          "type": "string",
          "description": "PVC storage size"
        },
        "annotations": {
          "type": "object",
          "description": "PVC annotations"
        },
        "labels": {
          "type": "object",
          "description": "PVC labels"
        }
      }
    },
    "extraVolumes": {
      "type": "array",
      "description": "Additional volumes",
      "items": {
        "type": "object"
      }
    },
    "extraVolumeMounts": {
      "type": "array",
      "description": "Additional volume mounts",
      "items": {
        "type": "object"
      }
    },
    "extraContainers": {
      "type": "array",
      "description": "Additional containers",
      "items": {
        "type": "object"
      }
    },
    "extraObjects": {
      "type": "array",
      "description": "Additional Kubernetes objects to create",
      "items": {
        "type": "object"
      }
    }
  },
  "if": {
    "properties": {
      "existingSecret": {
        "properties": { "name": { "minLength": 1 } },
        "required": ["name"]
      }
    }
  },
  "then": {
    "properties": {
      "externalSecret": {
        "properties": { "enabled": { "const": false } }
      }
    }
  }
}